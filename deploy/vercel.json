{
  "version": 2,
  "builds": [
    {
      "src": "api/routes/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/routes/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/app.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "functions": {
    "api/routes/*.py": {
      "runtime": "python3.11"
    }
  }
}
