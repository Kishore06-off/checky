# GovCheck AI - Environment Variables

# Groq API Configuration for LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_GENERATOR_MODEL=deepseek-r1-distill-llama-70b

# Embedding Model Configuration
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# Directory Paths
CHROMA_PERSIST_DIR=./chroma_db
OUTPUT_DIR=./output
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
JOB_STATUS_TTL_SEC=86400
CELERY_TASK_SOFT_TIME_LIMIT_SEC=1500
CELERY_TASK_TIME_LIMIT_SEC=1800
MAX_UPLOAD_MB=50
UPLOAD_CHUNK_SIZE_BYTES=1048576
LOCAL_JOB_STATUS_TTL_SEC=3600
LOCAL_JOB_STATUS_MAX_ITEMS=2000
MAX_INGESTION_CHUNKS=5000

# Chunking / semantic chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP=128
SEMANTIC_SIM_THRESHOLD=0.70
SEMANTIC_MIN_TOKENS=128

# Retrieval tuning
SEARCH_WEIGHT_ALPHA=0.7
RETRIEVAL_FETCH_MULTIPLIER=3
CHECKLIST_TOP_K=12
CHAT_TOP_K=5

# Optional cross-encoder re-ranking (downloads model on first use)
RERANK_ENABLE=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_CANDIDATE_MULTIPLIER=2

# Redis and queue runtime hardening
REDIS_SOCKET_TIMEOUT_SEC=1.0
REDIS_CONNECT_TIMEOUT_SEC=1.0
REDIS_HEALTH_CHECK_INTERVAL_SEC=30
CELERY_RESULT_EXPIRES_SEC=3600
CELERY_BROKER_POOL_LIMIT=20

# LLM client timeout/retry settings
GROQ_TIMEOUT_SEC=45
GROQ_MAX_RETRIES=2
