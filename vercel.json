{
  "version": 2,
  "builds": [
    {
      "src": "api/health.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 10,
        "runtime": "python3.11",
        "installCommand": "pip install -r requirements-minimal.txt"
      }
    },
    {
      "src": "api/upload.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 30,
        "runtime": "python3.11",
        "installCommand": "pip install -r requirements-minimal.txt"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/upload",
      "dest": "/api/upload.py"
    },
    {
      "src": "/health",
      "dest": "/api/health.py"
    },
    {
      "src": "/",
      "dest": "/api/health.py"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "build": {
    "env": {
      "PYTHONPATH": "$PYTHONPATH:/var/task"
    }
  },
  "installCommand": "pip install -r requirements-minimal.txt",
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": "."
}
