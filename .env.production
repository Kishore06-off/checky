# Production Environment Configuration for GovCheck AI

# API Configuration
ENVIRONMENT=production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./chroma_db

# LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_BATCH_SIZE=512

# File Processing
MAX_FILE_SIZE=50MB
OUTPUT_DIR=./output
DATA_DIR=./data

# Security
SECRET_KEY=your_secret_key_here
CORS_ORIGINS=["*"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# NanoClow Configuration
NANOCLAW_ENABLED=false
NANOCLAW_SERVICE_URL=http://localhost:3001
NANOCLAW_TIMEOUT_SEC=30

# Performance
MAX_WORKERS=4
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# Grounding Validation
GROUNDING_MIN_CONFIDENCE=0.8
GROUNDING_VALIDATION_ENABLED=true
